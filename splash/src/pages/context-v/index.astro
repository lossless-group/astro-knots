---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import KnotMark from '@components/KnotMark.astro';
import ModeToggle from '@components/ModeToggle.astro';
import { STATIC_SEO } from '@lib/seo';

const base = import.meta.env.BASE_URL;

let entries: Awaited<ReturnType<typeof getCollection<'context-v'>>> = [];
try {
  entries = (await getCollection('context-v')).filter((e) => e.data.publish !== false);
} catch {
  entries = [];
}

type Group = { key: string; label: string; entries: typeof entries };

function deriveSection(id: string): string {
  const segments = id.split('/');
  if (segments.length <= 2) return 'general';
  return segments[1];
}

const groupMap = new Map<string, typeof entries>();
for (const e of entries) {
  const key = deriveSection(e.id);
  if (!groupMap.has(key)) groupMap.set(key, []);
  groupMap.get(key)!.push(e);
}

const sectionOrder = ['specs', 'blueprints', 'plans', 'prompts', 'chores', 'reminders', 'explorations', 'strategy', 'issues', 'habits', 'sitemap', 'extra', 'general'];
const groups: Group[] = [...groupMap.entries()]
  .map(([key, es]) => ({
    key,
    label: key.charAt(0).toUpperCase() + key.slice(1).replace(/-/g, ' '),
    entries: es.sort((a, b) => (a.data.title ?? a.id).localeCompare(b.data.title ?? b.id)),
  }))
  .sort((a, b) => {
    const ai = sectionOrder.indexOf(a.key);
    const bi = sectionOrder.indexOf(b.key);
    if (ai !== -1 && bi !== -1) return ai - bi;
    if (ai !== -1) return -1;
    if (bi !== -1) return 1;
    return a.key.localeCompare(b.key);
  });
---

<BaseLayout title={STATIC_SEO.contextVIndex.title} description={STATIC_SEO.contextVIndex.description}>
  <header class="archive-topbar">
    <div class="container archive-topbar__inner">
      <a class="archive-topbar__brand" href={base}>
        <KnotMark size={28} static />
        <span class="mono">astro-knots</span>
      </a>
      <ModeToggle />
    </div>
  </header>

  <main class="container archive">
    <header class="archive__head">
      <p class="eyebrow">The thinking</p>
      <h1 class="display">Notes</h1>
      <p class="archive__lede">
        Specs, blueprints, prompts, reminders, strategy. Living documentation that underwrites the
        code, kept in each repo's <code>context-v/</code> and rendered here when marked publishable.
      </p>
      <p class="archive__back mono">
        <a href={base}>← Back to splash</a>
      </p>
    </header>

    {groups.length === 0 ? (
      <div class="archive__empty">
        <p>No published notes yet.</p>
        <p class="dim">
          Drop files into <code>astro-knots/context-v/</code> (or sync the rollup), mark them
          <code>publish: true</code> (or omit the field), and they'll appear here on the next deploy.
        </p>
      </div>
    ) : (
      <div class="groups">
        {groups.map((g) => (
          <section class="group">
            <h2 class="group__label">{g.label}</h2>
            <ul class="group__list">
              {g.entries.map((entry) => (
                <li>
                  <a href={`${base}context-v/${entry.id}`}>
                    {entry.data.from && entry.data.from !== 'astro-knots' && (
                      <span class="from-tag">{entry.data.from}</span>
                    )}
                    <h3 class="display">{entry.data.title ?? entry.id.split('/').pop()}</h3>
                    {entry.data.lede && <p>{entry.data.lede}</p>}
                    {!entry.data.lede && entry.data.description && <p>{entry.data.description}</p>}
                    {!entry.data.lede && !entry.data.description && entry.data.purpose && <p>{entry.data.purpose}</p>}
                    <div class="group__meta">
                      {entry.data.status && <span class="pill" data-status={entry.data.status}>{entry.data.status}</span>}
                      {entry.data.semantic_version && <span class="mono dim">v{entry.data.semantic_version}</span>}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .archive-topbar {
    border-bottom: 1px solid var(--color-border);
    padding: 14px 0;
    background: color-mix(in oklab, var(--color-bg) 80%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .archive-topbar__inner {
    display: flex; justify-content: space-between; align-items: center; gap: var(--space-6);
  }
  .archive-topbar__brand {
    display: inline-flex; align-items: center; gap: var(--space-3); color: var(--color-text);
  }

  .archive { padding: clamp(3rem, 8vh, 6rem) 0 var(--space-16); }
  .archive__head { margin-bottom: var(--space-12); max-width: 720px; }
  .archive__head h1 { margin-top: var(--space-3); font-size: clamp(2.25rem, 5vw, 3.5rem); }
  .archive__lede { margin-top: var(--space-4); color: var(--color-text-soft); font-size: 1.05rem; }
  .archive__lede code {
    font-family: var(--font__mono);
    background: color-mix(in oklab, var(--color-accent) 14%, transparent);
    color: var(--color-accent);
    padding: 2px 6px; border-radius: 4px; font-size: 0.9em;
  }
  .archive__back { margin-top: var(--space-6); font-size: 0.875rem; }
  .archive__empty {
    padding: var(--space-12);
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-md);
    text-align: center;
    color: var(--color-text-soft);
  }
  .archive__empty .dim { color: var(--color-text-dim); margin-top: var(--space-3); font-size: 0.9rem; }
  .archive__empty code {
    font-family: var(--font__mono);
    background: color-mix(in oklab, var(--color-text) 5%, transparent);
    padding: 2px 6px; border-radius: 4px; color: var(--color-accent);
  }

  .groups { display: grid; gap: var(--space-12); }
  .group__label {
    font-family: var(--font__mono);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-thread);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }
  .group__list {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-3);
  }
  .group__list a {
    display: block;
    padding: var(--space-6);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text);
    height: 100%;
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .group__list a:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
    color: var(--color-text);
  }
  .group__list h3 { font-size: 1.1rem; margin-bottom: var(--space-2); color: var(--color-text); }
  .group__list p { color: var(--color-text-soft); font-size: 0.95rem; margin-bottom: var(--space-3); }
  .group__meta { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; }
  .dim { color: var(--color-text-dim); }
</style>
