---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import KnotMark from '@components/KnotMark.astro';
import ModeToggle from '@components/ModeToggle.astro';
import { getSiteOgImage } from '@lib/seo';

export async function getStaticPaths() {
  let entries: Awaited<ReturnType<typeof getCollection<'context-v'>>> = [];
  try {
    entries = (await getCollection('context-v')).filter((e) => e.data.publish !== false);
  } catch { entries = []; }
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const date = entry.data.date_modified ?? entry.data.date_updated ?? entry.data.date_created;
const base = import.meta.env.BASE_URL;
const segments = entry.id.split('/');
const sectionLabel = segments.length > 2 ? segments[1] : 'general';

const pageTitle = entry.data.title ?? entry.id.split('/').pop() ?? entry.id;
const pageDescription =
  entry.data.lede ?? entry.data.description ?? entry.data.purpose ??
  `${sectionLabel.charAt(0).toUpperCase() + sectionLabel.slice(1)} note from ${entry.data.from ?? 'astro-knots'}.`;
const siteOg = await getSiteOgImage(entry.data.from);
const publishedTime = (entry.data.date_created)?.toISOString();
const modifiedTime = (entry.data.date_modified ?? entry.data.date_updated ?? entry.data.date_created)?.toISOString();
const articleAuthor = entry.data.authors?.[0];
const articleTags = entry.data.tags;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={siteOg}
  ogType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  author={articleAuthor}
  tags={articleTags}
>
  <header class="reading-topbar">
    <div class="container reading-topbar__inner">
      <a class="reading-topbar__brand" href={base}>
        <KnotMark size={28} static />
        <span class="mono">astro-knots</span>
      </a>
      <ModeToggle />
    </div>
  </header>

  <main class="container reading">
    <p class="reading__back mono">
      <a href={`${base}context-v`}>← All notes</a>
    </p>

    <article>
      <header class="reading__head">
        <p class="reading__section">{sectionLabel}</p>
        <h1 class="display">{entry.data.title ?? entry.id.split('/').pop()}</h1>
        {entry.data.lede && <p class="reading__lede">{entry.data.lede}</p>}
        {!entry.data.lede && entry.data.description && <p class="reading__lede">{entry.data.description}</p>}
        {!entry.data.lede && !entry.data.description && entry.data.purpose && <p class="reading__lede">{entry.data.purpose}</p>}
        <div class="reading__meta">
          {entry.data.from && entry.data.from !== 'astro-knots' && (
            <span class="from-tag">{entry.data.from}</span>
          )}
          {entry.data.status && <span class="pill" data-status={entry.data.status}>{entry.data.status}</span>}
          {entry.data.semantic_version && <span class="pill mono">v{entry.data.semantic_version}</span>}
          {date && (
            <time class="mono dim" datetime={new Date(date).toISOString()}>
              {new Date(date).toISOString().slice(0, 10)}
            </time>
          )}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  .prose {
    max-width: 70ch;
    margin: 0 auto;
    color: var(--color-text-soft);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .prose h1, .prose h2, .prose h3, .prose h4 {
    color: var(--color-text);
    font-family: var(--font__display);
    margin-top: 2.5em;
    margin-bottom: 0.5em;
    line-height: 1.15;
  }
  .prose h1 { font-size: 2rem; }
  .prose h2 { font-size: 1.5rem; }
  .prose h3 { font-size: 1.2rem; }
  .prose p { margin: 1em 0; }
  .prose ul, .prose ol { padding-left: 1.5em; margin: 1em 0; }
  .prose li { margin: 0.4em 0; }
  .prose a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { color: var(--color-accent-warm); }
  .prose code {
    font-family: var(--font__mono);
    background: color-mix(in oklab, var(--color-text) 5%, transparent);
    padding: 2px 6px; border-radius: 4px; font-size: 0.9em;
    color: var(--color-thread);
  }
  .prose pre {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    padding: 1.25em; border-radius: var(--radius-md);
    overflow-x: auto; font-size: 0.9rem;
  }
  .prose pre code { background: transparent; padding: 0; color: var(--color-text-soft); }
  .prose blockquote {
    margin: 1.5em 0; padding-left: 1.25em;
    border-left: 3px solid var(--color-border-accent);
    color: var(--color-text-dim); font-style: italic;
  }
  .prose hr { border: 0; border-top: 1px solid var(--color-border); margin: 3em 0; }
  .prose img { max-width: 100%; border-radius: var(--radius-md); }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.5em 0; }
  .prose th, .prose td {
    padding: 0.5em 0.75em; border-bottom: 1px solid var(--color-border); text-align: left;
  }
  .prose th { color: var(--color-text); font-weight: 600; }
</style>

<style>
  .reading-topbar {
    border-bottom: 1px solid var(--color-border);
    padding: 14px 0;
    background: color-mix(in oklab, var(--color-bg) 80%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .reading-topbar__inner {
    display: flex; justify-content: space-between; align-items: center; gap: var(--space-6);
  }
  .reading-topbar__brand {
    display: inline-flex; align-items: center; gap: var(--space-3); color: var(--color-text);
  }
  .reading { padding: clamp(3rem, 8vh, 6rem) 0 var(--space-16); }
  .reading__back { font-size: 0.875rem; margin-bottom: var(--space-8); }
  .reading__head { max-width: 70ch; margin: 0 auto var(--space-12); }
  .reading__section {
    font-family: var(--font__mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-thread);
    margin-bottom: var(--space-3);
  }
  .reading__head h1 { font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.05; }
  .reading__lede {
    margin-top: var(--space-4);
    color: var(--color-text-soft);
    font-size: 1.15rem;
    line-height: 1.5;
  }
  .reading__meta {
    margin-top: var(--space-6);
    display: flex; gap: var(--space-3); align-items: center; flex-wrap: wrap;
  }
  .dim { color: var(--color-text-dim); }
</style>
