---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ContentCollectionSelectorRow from '@components/ContentCollectionSelector--Row.astro';
import KnotMark from '@components/KnotMark.astro';
import ModeToggle from '@components/ModeToggle.astro';
import { STATIC_SEO } from '@lib/seo';

const base = import.meta.env.BASE_URL;

let entries: Awaited<ReturnType<typeof getCollection<'changelog'>>> = [];
try {
  entries = (await getCollection('changelog'))
    .filter((e) => e.data.publish !== false)
    .sort((a, b) => {
      const da = a.data.date_modified ?? a.data.date_created ?? a.data.date ?? new Date(0);
      const db = b.data.date_modified ?? b.data.date_created ?? b.data.date ?? new Date(0);
      return new Date(db).getTime() - new Date(da).getTime();
    });
} catch {
  entries = [];
}

const counts = new Map<string, number>();
for (const e of entries) {
  const from = (e.data.from as string | undefined) ?? 'astro-knots';
  counts.set(from, (counts.get(from) ?? 0) + 1);
}

const filterOptions = [...counts.entries()]
  .map(([value, count]) => ({ value, label: value, count }))
  .sort((a, b) => {
    if (a.value === 'astro-knots') return -1;
    if (b.value === 'astro-knots') return 1;
    return a.value.localeCompare(b.value);
  });
---

<BaseLayout title={STATIC_SEO.changelogIndex.title} description={STATIC_SEO.changelogIndex.description}>
  <header class="archive-topbar">
    <div class="container archive-topbar__inner">
      <a class="archive-topbar__brand" href={base}>
        <KnotMark size={28} static />
        <span class="mono">astro-knots</span>
      </a>
      <ModeToggle />
    </div>
  </header>

  <main class="container archive">
    <header class="archive__head">
      <p class="eyebrow">Ship log</p>
      <h1 class="display">Changelog</h1>
      <p class="archive__lede">
        What landed across the workspace, and when. Each entry links back to the spec or blueprint
        that asked for it. Entries from sibling sites are tagged with their slug.
      </p>
      <p class="archive__back mono">
        <a href={base}>← Back to splash</a>
      </p>
    </header>

    {entries.length === 0 ? (
      <div class="archive__empty">
        <p>No published ship notes yet.</p>
        <p class="dim">
          Either <code>astro-knots/changelog/</code> is empty, or the rolled-up content hasn't been
          synced. Run <code>pnpm rollup:sync</code> from <code>splash/</code> to refresh.
        </p>
      </div>
    ) : (
      <>
        <ContentCollectionSelectorRow
          options={filterOptions}
          targetSelector=".archive-list"
          matchAttribute="data-from"
          label="Filter changelog by site"
        />
        <ul class="archive-list">
          {entries.map((entry) => {
            const date = entry.data.date_modified ?? entry.data.date_created ?? entry.data.date;
            const from = (entry.data.from as string | undefined) ?? 'astro-knots';
            return (
              <li data-from={from}>
                <a href={`${base}changelog/${entry.id}`}>
                  <div class="archive-meta">
                    {entry.data.from && entry.data.from !== 'astro-knots' && (
                      <span class="from-tag mono">{entry.data.from}</span>
                    )}
                    {date && (
                      <time class="mono" datetime={new Date(date).toISOString()}>
                        {new Date(date).toISOString().slice(0, 10)}
                      </time>
                    )}
                    {entry.data.at_semantic_version && (
                      <span class="pill">{entry.data.at_semantic_version}</span>
                    )}
                    {entry.data.legacy && (
                      <span class="pill mono" title="From a legacy context-v/changelogs/ path">legacy</span>
                    )}
                  </div>
                  <h2 class="display">{entry.data.title ?? entry.id}</h2>
                  {entry.data.lede && <p>{entry.data.lede}</p>}
                </a>
              </li>
            );
          })}
        </ul>
      </>
    )}
  </main>
</BaseLayout>

<style>
  .archive-topbar {
    border-bottom: 1px solid var(--color-border);
    padding: 14px 0;
    background: color-mix(in oklab, var(--color-bg) 80%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .archive-topbar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-6);
  }
  .archive-topbar__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
  }

  .archive { padding: clamp(3rem, 8vh, 6rem) 0 var(--space-16); }
  .archive__head { margin-bottom: var(--space-12); max-width: 720px; }
  .archive__head h1 { margin-top: var(--space-3); font-size: clamp(2.25rem, 5vw, 3.5rem); }
  .archive__lede { margin-top: var(--space-4); color: var(--color-text-soft); font-size: 1.05rem; }
  .archive__back { margin-top: var(--space-6); font-size: 0.875rem; }
  .archive__empty {
    padding: var(--space-12);
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-md);
    text-align: center;
    color: var(--color-text-soft);
  }
  .archive__empty .dim { color: var(--color-text-dim); margin-top: var(--space-3); font-size: 0.9rem; }
  .archive__empty code {
    font-family: var(--font__mono);
    background: color-mix(in oklab, var(--color-text) 5%, transparent);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--color-accent);
  }
  .archive-list { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-3); }
  .archive-list a {
    display: block;
    padding: var(--space-6);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text);
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .archive-list a:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
    color: var(--color-text);
  }
  .archive-meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    color: var(--color-text-dim);
    font-size: 0.8rem;
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
  }
  .archive-list h2 { font-size: 1.25rem; margin-bottom: var(--space-2); }
  .archive-list p { color: var(--color-text-soft); font-size: 0.95rem; }
</style>
