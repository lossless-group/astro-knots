---
/**
 * SiteCard — one Astro site in the gallery.
 *
 * The card has a "thread" — a thin animated gradient strip across the top
 * that uses the per-site brand color from `--thread__<slug>` (declared in
 * theme.css). It runs continuously to suggest the site is "tied into" the
 * lattice. Pointer-tracked highlight gives the card a tactile feel.
 */

interface Props {
  title: string;
  slug: string;
  lede?: string;
  status?: string;
  repo?: string;
  liveUrl?: string;
  icon?: string;
  featured?: boolean;
  tags?: string[];
  threadColor?: string;
  maintainedBy?: string;
}

const {
  title,
  slug,
  lede,
  status,
  repo,
  liveUrl,
  icon,
  featured = false,
  tags = [],
  threadColor,
  maintainedBy,
} = Astro.props;

const primaryHref = liveUrl ?? repo ?? '#';
const primaryExternal = primaryHref !== '#';

// Resolve thread color: explicit prop wins; else derive from slug via theme.css.
const threadStyle = threadColor
  ? `--site-thread: ${threadColor};`
  : `--site-thread: var(--thread__${slug}, var(--color-thread));`;
---

<article
  class:list={["site-card", { "site-card--featured": featured }]}
  style={threadStyle}
  data-site={slug}
>
  <a
    class="site-card__link"
    href={primaryHref}
    target={primaryExternal ? '_blank' : '_self'}
    rel={primaryExternal ? 'noopener' : undefined}
  >
    <div class="site-card__thread" aria-hidden="true"></div>
    <div class="site-card__inner">
      <header class="site-card__head">
        {icon && <div class="site-card__icon" aria-hidden="true">{icon}</div>}
        <div class="site-card__title-block">
          <h3 class="site-card__title">{title}</h3>
          {status && <span class="pill" data-status={status}>{status}</span>}
        </div>
      </header>
      {lede && <p class="site-card__lede">{lede}</p>}
      <footer class="site-card__foot">
        {tags.length > 0 && (
          <ul class="site-card__tags">
            {tags.map((t) => <li>{t}</li>)}
          </ul>
        )}
        <div class="site-card__links">
          {liveUrl && (
            <span class="site-card__link-pill mono" aria-hidden="true">live ↗</span>
          )}
          {repo && !liveUrl && (
            <span class="site-card__link-pill mono" aria-hidden="true">repo ↗</span>
          )}
        </div>
      </footer>
      {maintainedBy && (
        <p class="site-card__attribution mono">{maintainedBy}</p>
      )}
    </div>
  </a>
</article>

<style>
  .site-card {
    --site-thread: var(--color-thread);
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    transition:
      border-color 280ms ease,
      transform 280ms ease,
      box-shadow 280ms ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .site-card:hover {
    border-color: color-mix(in oklab, var(--site-thread) 65%, transparent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }
  .site-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: var(--color-text);
    text-decoration: none;
  }
  .site-card__link:hover { color: var(--color-text); }

  .site-card__thread {
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--site-thread) 25%,
      color-mix(in oklab, var(--site-thread) 60%, var(--color-thread)) 60%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: thread-flow 6s linear infinite;
  }
  @keyframes thread-flow {
    from { background-position: 200% 0; }
    to { background-position: -200% 0; }
  }

  .site-card__inner {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    flex: 1 1 auto;
  }

  .site-card__head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .site-card__icon {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: color-mix(in oklab, var(--site-thread) 14%, transparent);
    border: 1px solid color-mix(in oklab, var(--site-thread) 30%, transparent);
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .site-card__title-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-start;
    min-width: 0;
  }
  .site-card__title {
    font-family: var(--font__mono);
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .site-card--featured .site-card__title {
    font-size: 1.2rem;
  }
  .site-card__lede {
    color: var(--color-text-soft);
    font-size: 0.95rem;
    line-height: 1.55;
    flex: 1 1 auto;
  }
  .site-card__foot {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .site-card__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .site-card__tags li {
    font-family: var(--font__mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--color-text-dim);
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }
  .site-card__link-pill {
    font-size: 0.75rem;
    color: var(--site-thread);
    opacity: 0.85;
  }
  .site-card__attribution {
    font-size: 0.72rem;
    color: var(--color-text-dimmer);
    margin-top: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px dashed var(--color-border);
  }
</style>
